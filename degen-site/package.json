{
  "name": "degen-site",
  "version": "0.4.14",
  "description": "Degen4 - Internal tool to support sports league tracking",
  "private": true,
  "dependencies": {
    "@apollo/client": "^3.13.9",
    "@aws-amplify/auth": "^6.16.0",
    "@aws-amplify/core": "^6.13.3",
    "@aws-sdk/client-cognito-identity": "^3.922.0",
    "@aws-sdk/client-cognito-identity-provider": "^3.922.0",
    "@aws-sdk/client-dynamodb": "^3.922.0",
    "@aws-sdk/client-s3": "^3.922.0",
    "@aws-sdk/client-sts": "^3.922.0",
    "@aws-sdk/credential-provider-cognito-identity": "^3.922.0",
    "@aws-sdk/lib-dynamodb": "^3.922.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^13.5.0",
    "amazon-cognito-identity-js": "^6.3.15",
    "apollo-client": "^2.6.10",
    "apollo-server-express": "^3.13.0",
    "apollo-server-lambda": "^3.13.0",
    "dotenv": "^17.2.1",
    "graphql": "^15.10.1",
    "graphql-tag": "^2.12.6",
    "node-fetch": "^3.3.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-scripts": "5.0.1",
    "uuid": "^11.1.0",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "node scripts/generateVersion.js && react-scripts build && node scripts/generateVersion.js",
    "ci": "npm test -- --watchAll=false && npm run build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "graphql:start": "node scripts/startGraphQLServer.js",
    "dev": "concurrently \"npm run graphql:start\" \"npm start\"",
    "graphql:playground": "open http://localhost:4000/graphql",
    "update-odds": "node scripts/updateWorldSeriesOdds.js",
    "update-odds:force": "node scripts/updateWorldSeriesOdds.js --force-fallback",
    "update-odds:python": "python3 scripts/updateWorldSeriesOdds.py",
    "update-odds:auto": "./scripts/update-odds.sh",
    "update-nfl-owners": "node scripts/updateNflOwners.js",
    "populate-ncaa": "node scripts/populateNcaaDataWithMapping.js",
    "update-ncaa": "node scripts/updateNcaaData.js",
    "fix-ncaa-names": "node scripts/fixNcaaTeamNames.js",
    "cleanup-ncaa": "node scripts/cleanupNcaaData.js",
    "cleanup-duplicates": "node scripts/cleanupDuplicateTeams.js",
    "clear-ncaa": "node scripts/clearNcaaData.js",
    "add-florida-state": "node scripts/addFloridaState.js",
    "update-ncaa-conferences": "node scripts/updateNcaaConferences.js",
    "fix-ohio-state": "node scripts/fixOhioState.js",
    "update-ncaa-payout": "node scripts/updateNcaaPayout.js",
    "update-ncaa-records": "node scripts/updateNcaaRecords.js",
    "fix-alabama-odds": "node scripts/fixAlabamaOdds.js",
    "validate-all-odds": "node scripts/validateAllOdds.js",
    "fix-incorrect-odds": "node scripts/fixIncorrectOdds.js",
    "compare-api-ids": "node scripts/compareApiIds.js",
    "populate-team-mappings": "node scripts/populateTeamMappings.js",
    "populate-ncaa-with-mapping": "node scripts/populateNcaaDataWithMapping.js",
    "check-missing-teams": "node scripts/checkMissingTeams.js",
    "add-missing-mappings": "node scripts/addMissingMappings.js",
    "export-mappings": "node scripts/exportMappingTableToCSV.js",
    "repopulate-mappings": "node scripts/repopulateMappingTable.js",
    "repopulate-ncaa-teams": "node scripts/repopulateNcaaTeams.js",
    "sync-draft-picks": "node scripts/syncDraftPicks.js",
    "populate-ncaa-legacy": "node scripts/populateNcaaData.js",
    "test-draft": "node scripts/testDraft.js",
    "clear-draft": "node scripts/clearDraft.js",
    "setup-env": "node scripts/setup-env.js",
    "test-nfl-api": "node scripts/testNflApi.js",
    "update-nfl-data": "node scripts/updateNflData.js",
    "update-nfl-data-fixed": "node scripts/updateNflDataFixed.js",
    "test-nfl-odds": "node scripts/testNflOdds.js",
    "update-nfl-odds": "node scripts/updateNflOdds.js",
    "update-nba-data": "node scripts/updateNbaData.js",
    "fix-update-button": "node scripts/fixUpdateTeamDataButton.js",
    "test-update-button": "node scripts/testUpdateButton.js",
    "test-draft-order": "node scripts/testDraftOrder.js",
    "fix-nfl-duplicates": "node scripts/fixNflDuplicates.js",
    "test-draft-order-ui": "node scripts/testDraftOrderUI.js",
    "test-dynamic-owner-order": "node scripts/testDynamicOwnerOrder.js",
    "test-payout-table-order": "node scripts/testPayoutTableOrder.js",
    "test-draft-dropdown": "node scripts/testDraftTeamDropdown.js",
    "reinit-nfl-draft": "node scripts/reinitializeNflDraft.js",
    "clear-reinit-nfl-draft": "node scripts/clearAndReinitNflDraft.js",
    "setup-dynamodb": "node scripts/setupDynamoDB.js",
    "migrate-to-dynamodb": "node scripts/migrateToDynamoDB.js",
    "setup-frontend-s3": "node scripts/setupFrontendS3.js",
    "deploy-frontend": "node scripts/deployFrontend.js",
    "deploy-frontend:no-bump": "DEPLOY_SKIP_VERSION_BUMP=1 node scripts/deployFrontend.js",
    "setup-cognito-identity-pool": "node scripts/setupCognitoIdentityPool.js",
    "setup-backend-ec2": "node scripts/setupBackendEC2.js",
    "prepare-backend": "node scripts/prepareBackendDeployment.js",
    "deploy-lambda": "node scripts/deployLambda.js"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "archiver": "^7.0.1",
    "concurrently": "^9.2.0"
  }
}
