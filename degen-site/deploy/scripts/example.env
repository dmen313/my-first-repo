# Example environment variables for NCAA data population script
# Copy this file to .env in the root directory and fill in your actual API keys
# 
# Usage:
# 1. cp scripts/example.env .env
# 2. Edit .env with your actual API keys
# 3. Run: npm run populate-ncaa

# The Odds API - Get your key from https://the-odds-api.com/
ODDS_API_KEY=your_odds_api_key_here

# College Football Data API - Get your key from https://collegefootballdata.com/
CFBD_API_KEY=your_cfbd_api_key_here

# Optional: React app odds API key (for other scripts)
REACT_APP_ODDS_API_KEY=your_odds_api_key_here

# Optional: NFL API key (for NFL data scripts)
REACT_APP_NFL_API_KEY=your_nfl_api_key_here
